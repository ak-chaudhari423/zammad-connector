<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="f51c130" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.10.0">
  <bpmn:process id="Process_Zammad_Demo" name="Zammad Demo" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Employee  VPN Issue raised">
      <bpmn:outgoing>Flow_1lq9ind</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1lq9ind" sourceRef="StartEvent_1" targetRef="Activity_0du7a3p" />
    <bpmn:serviceTask id="Activity_0du7a3p" name="Search User" zeebe:modelerTemplate="io.camunda.zammad-connector-template" zeebe:modelerTemplateVersion="20" zeebe:modelerTemplateIcon="data:image/png;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.ZAMMAD_TOKEN}}" target="accesstoken" />
          <zeebe:input source="searchUser" target="zammadOperation" />
          <zeebe:input source="https://e67a-103-200-106-79.ngrok-free.app" target="baseUrl" />
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=baseUrl + &#34;/api/v1/users/search?query=&#34; + email" target="url" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="application/json" target="headers.ContentType" />
          <zeebe:input source="= &#34;Token token=&#34; + accesstoken" target="headers.Authorization" />
          <zeebe:input source="120" target="connectionTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="result" />
          <zeebe:header key="resultExpression" value="={ isUserResult: response.body[1] }" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1lq9ind</bpmn:incoming>
      <bpmn:outgoing>Flow_0dgkatw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_1t064ql" default="Flow_1bavg9i">
      <bpmn:incoming>Flow_0dgkatw</bpmn:incoming>
      <bpmn:outgoing>Flow_1bavg9i</bpmn:outgoing>
      <bpmn:outgoing>Flow_0p01c4f</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0dgkatw" sourceRef="Activity_0du7a3p" targetRef="Gateway_1t064ql" />
    <bpmn:sequenceFlow id="Flow_1bavg9i" sourceRef="Gateway_1t064ql" targetRef="Activity_01ioaj5" />
    <bpmn:exclusiveGateway id="Gateway_1po9o1w">
      <bpmn:incoming>Flow_0cdwzow</bpmn:incoming>
      <bpmn:incoming>Flow_0p01c4f</bpmn:incoming>
      <bpmn:outgoing>Flow_0894qmu</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0cdwzow" sourceRef="Activity_01ioaj5" targetRef="Gateway_1po9o1w" />
    <bpmn:sequenceFlow id="Flow_0p01c4f" sourceRef="Gateway_1t064ql" targetRef="Gateway_1po9o1w">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isUserResult.email = email</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0894qmu" sourceRef="Gateway_1po9o1w" targetRef="Activity_1y9xakm" />
    <bpmn:serviceTask id="Activity_1voli2t" name="Send customer reply" zeebe:modelerTemplate="io.camunda.connectors.email.v1" zeebe:modelerTemplateVersion="4" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:email:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="simple" target="authentication.type" />
          <zeebe:input source="{{secrets.USERNAME}}" target="authentication.username" />
          <zeebe:input source="{{secrets.PASSWORD}}" target="authentication.password" />
          <zeebe:input source="smtp" target="protocol" />
          <zeebe:input source="smtp.gmail.com" target="data.smtpConfig.smtpHost" />
          <zeebe:input source="=587" target="data.smtpConfig.smtpPort" />
          <zeebe:input source="TLS" target="data.smtpConfig.smtpCryptographicProtocol" />
          <zeebe:input source="sendEmailSmtp" target="data.smtpActionDiscriminator" />
          <zeebe:input source="{{secrets.USERNAME}}" target="data.smtpAction.from" />
          <zeebe:input source="=email" target="data.smtpAction.to" />
          <zeebe:input source="Issue has been resolved" target="data.smtpAction.subject" />
          <zeebe:input source="PLAIN" target="data.smtpAction.contentType" />
          <zeebe:input source="Hi ,&#10; Your Issue has been resolved" target="data.smtpAction.body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="4" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.email.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0h8r5on</bpmn:incoming>
      <bpmn:outgoing>Flow_0zdrsrx</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0zdrsrx" sourceRef="Activity_1voli2t" targetRef="Activity_16z2dl3" />
    <bpmn:sequenceFlow id="Flow_0h8r5on" sourceRef="Activity_1f0cmha" targetRef="Activity_1voli2t" />
    <bpmn:endEvent id="Event_0mndolw" name="VPN issue raised">
      <bpmn:incoming>Flow_02yqe3f</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_02yqe3f" sourceRef="Activity_16z2dl3" targetRef="Event_0mndolw" />
    <bpmn:userTask id="Activity_1f0cmha" name="Review by IT engineer">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1y8ec9h</bpmn:incoming>
      <bpmn:outgoing>Flow_0h8r5on</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_01ioaj5" name="Create user" zeebe:modelerTemplate="io.camunda.zammad-connector-template" zeebe:modelerTemplateVersion="20" zeebe:modelerTemplateIcon="data:image/png;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.ZAMMAD_TOKEN}}" target="accesstoken" />
          <zeebe:input source="createUser" target="zammadOperation" />
          <zeebe:input source="https://e67a-103-200-106-79.ngrok-free.app" target="baseUrl" />
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=firstName" target="firstName" />
          <zeebe:input source="lastName" target="lastName" />
          <zeebe:input source="=baseUrl + &#34;/api/v1/users&#34;" target="url" />
          <zeebe:input source="POST" target="method" />
          <zeebe:input source="application/json" target="headers.ContentType" />
          <zeebe:input source="= &#34;Token token=&#34; + accesstoken" target="headers.Authorization" />
          <zeebe:input source="={&#34;firstname&#34;: firstname,&#34;lastname&#34;: lastname,&#34;email&#34;: email,&#34;role_ids&#34;: [3]}" target="body" />
          <zeebe:input source="120" target="connectionTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="result" />
          <zeebe:header key="resultExpression" value="={ result: response.body }" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1bavg9i</bpmn:incoming>
      <bpmn:outgoing>Flow_0cdwzow</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_1y9xakm" name="Create ticket" zeebe:modelerTemplate="io.camunda.zammad-connector-template" zeebe:modelerTemplateVersion="20" zeebe:modelerTemplateIcon="data:image/png;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.ZAMMAD_TOKEN}}" target="accesstoken" />
          <zeebe:input source="createTicket" target="zammadOperation" />
          <zeebe:input source="https://e67a-103-200-106-79.ngrok-free.app" target="baseUrl" />
          <zeebe:input source="=title" target="title" />
          <zeebe:input source="=group" target="group" />
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="open" target="state" />
          <zeebe:input target="priority" />
          <zeebe:input source="=subject" target="subject" />
          <zeebe:input source="=msgBody" target="messagebody" />
          <zeebe:input source="false" target="internal" />
          <zeebe:input source="= baseUrl + &#34;/api/v1/tickets&#34;" target="url" />
          <zeebe:input source="POST" target="method" />
          <zeebe:input source="application/json" target="headers.ContentType" />
          <zeebe:input source="= &#34;Token token=&#34; + accesstoken" target="headers.Authorization" />
          <zeebe:input source="={&#34;title&#34;: title,&#34;customer&#34;: email,&#34;group&#34;: group,&#34;state&#34;: state,&#34;priority&#34;: priority,&#34;article&#34;:{&#34;subject&#34;: subject,&#34;body&#34;: messagebody,&#34;internal&#34;: if internal = &#34;true&#34; then true else false}}" target="body" />
          <zeebe:input source="120" target="connectionTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="result" />
          <zeebe:header key="resultExpression" value="={ createTicketResult: response.body }" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0894qmu</bpmn:incoming>
      <bpmn:outgoing>Flow_1y8ec9h</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_16z2dl3" name="Update ticket status (closed)" zeebe:modelerTemplate="io.camunda.zammad-connector-template" zeebe:modelerTemplateVersion="20" zeebe:modelerTemplateIcon="data:image/png;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.ZAMMAD_TOKEN}}" target="accesstoken" />
          <zeebe:input source="updateTicket" target="zammadOperation" />
          <zeebe:input source="https://e67a-103-200-106-79.ngrok-free.app" target="baseUrl" />
          <zeebe:input source="=title" target="title" />
          <zeebe:input source="=group" target="group" />
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="open" target="state" />
          <zeebe:input target="priority" />
          <zeebe:input source="=subject" target="subject" />
          <zeebe:input source="=msgBody" target="messagebody" />
          <zeebe:input source="=createTicketResult.id" target="ticketId" />
          <zeebe:input source="=string(baseUrl) + &#34;/api/v1/tickets/&#34; + string(ticketId)" target="url" />
          <zeebe:input source="PUT" target="method" />
          <zeebe:input source="application/json" target="headers.ContentType" />
          <zeebe:input source="= &#34;Token token=&#34; + accesstoken" target="headers.Authorization" />
          <zeebe:input source="={&#34;title&#34;: title,&#34;customer&#34;: email,&#34;group&#34;: group,&#34;state&#34;: state,&#34;priority&#34;: priority,&#34;article&#34;:{&#34;subject&#34;: subject,&#34;body&#34;: messagebody,&#34;internal&#34;: if internal = &#34;true&#34; then true else false}}" target="body" />
          <zeebe:input source="120" target="connectionTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="result" />
          <zeebe:header key="resultExpression" value="={ result: response.body }" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0zdrsrx</bpmn:incoming>
      <bpmn:outgoing>Flow_02yqe3f</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1y8ec9h" sourceRef="Activity_1y9xakm" targetRef="Activity_1f0cmha" />
    <bpmn:textAnnotation id="TextAnnotation_0jrj1d6">
      <bpmn:text>Assign Ticket to IT Engineer group using group option</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_03brev1" associationDirection="None" sourceRef="Activity_1y9xakm" targetRef="TextAnnotation_0jrj1d6" />
    <bpmn:textAnnotation id="TextAnnotation_04qwb97">
      <bpmn:text>(In Progress / Pending Customer)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1utteb4" associationDirection="None" sourceRef="Activity_1f0cmha" targetRef="TextAnnotation_04qwb97" />
  </bpmn:process>
