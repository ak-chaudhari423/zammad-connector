{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "google-meet-connector",
  "id": "io.camunda.google-meet.connector.template",
  "version": 17,
  "description": "Create, schedule, update, and cancel Google Meet meetings directly from Camunda workflows. Supports attendee invitations, calendar events, and Meet link generation using Google APIs.",
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "authentication",
      "label": "Authentication"
    },
    {
      "id": "operation",
      "label": "Operation"
    },
    {
      "id": "parameters",
      "label": "Parameters"
    },
    {
      "id": "requestBody",
      "label": "Request Body"
    },
    {
      "id": "output",
      "label": "Response mapping"
    },
    {
      "id": "errors",
      "label": "Error handling"
    },
    {
      "id": "retries",
      "label": "Retries"
    }
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "io.camunda:http-json:1",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "type"
      }
    },
    {
      "id": "accesstoken",
      "label": "Access Token",
      "description": "Enter Access Token",
      "type": "String",
      "group": "authentication",
      "feel": "optional",
      "binding": {
        "type": "zeebe:input",
        "name": "accesstoken"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "id": "meetingOperation",
      "label": "Meeting Option",
      "description": "Select Meeting Operation",
      "type": "Dropdown",
      "group": "operation",
      "value": "instantMeeting",
      "choices": [
        {
          "name": "Instant Meeting",
          "value": "instantMeeting"
        },
        {
          "name": "Schedule Meeting In Calendar",
          "value": "scheduleMeetingInCalendar"
        },
        {
          "name": "Update Meeting",
          "value": "updateMeeting"
        },
        {
          "name": "Cancel Meeting",
          "value": "cancelMeeting"
        }
      ],
      "binding": {
        "type": "zeebe:input",
        "name": "meetingOperation"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "id": "summary",
      "label": "summary",
      "description": "Enter the Summary",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "summary"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "meetingOperation",
        "oneOf": [
          "updateMeeting",
          "scheduleMeetingInCalendar",
          "cancelMeeting"
        ]
      }
    },
    {
      "id": "description",
      "label": "Description",
      "description": "Enter the Description",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "description"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "meetingOperation",
        "oneOf": [
          "updateMeeting",
          "scheduleMeetingInCalendar",
          "cancelMeeting"
        ]
      }
    },
    {
      "id": "startTime",
      "label": "Start Time",
      "description": "eg. 2026-06-25T10:00:00Z",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "startTime"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "meetingOperation",
        "oneOf": [
          "updateMeeting",
          "scheduleMeetingInCalendar"
        ]
      }
    },
    {
      "id": "endTime",
      "label": "End Time",
      "description": "eg. 2026-06-25T10:00:00Z  OR  2026-06-25T15:30:00+05:30 OR 026-06-25T10:00:00 with TimeZone",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "endTime"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "meetingOperation",
        "oneOf": [
          "updateMeeting",
          "scheduleMeetingInCalendar"
        ]
      }
    },
    {
      "id": "timeZone",
      "label": "Time Zone",
      "description": "eg. Asia/Kolkata",
      "feel": "optional",
      "value": "",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "timeZone"
      },
      "condition": {
        "property": "meetingOperation",
        "oneOf": [
          "updateMeeting",
          "scheduleMeetingInCalendar"
        ]
      }
    },
    {
      "id": "attendees",
      "label": "Enter Attendees Emails (JSON)",
      "description": "Example: [{\"email\":\"abc@gmail.com\"},{\"email\":\"xyz@gmail.com\"}]",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "attendees"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "meetingOperation",
        "oneOf": [
          "updateMeeting",
          "scheduleMeetingInCalendar"
        ]
      }
    },
    {
      "id": "eventId",
      "label": "Event ID",
      "description": "Google Calendar Event ID",
      "type": "Text",
      "feel": "optional",
      "group": "parameters",
      "binding": {
        "type": "zeebe:input",
        "name": "eventId"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "meetingOperation",
        "oneOf": [
          "updateMeeting",
          "cancelMeeting"
        ]
      }
    },
    {
      "id": "url",
      "label": "API URL",
      "description": "Google API URL",
      "type": "Hidden",
      "value": " https://meet.googleapis.com/v2/spaces",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "condition": {
        "property": "meetingOperation",
        "equals": "instantMeeting"
      }
    },
    {
      "id": "baseUrl",
      "value": "https://www.googleapis.com/calendar/v3/calendars/primary/events",
      "binding": {
        "name": "baseUrl",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "url",
      "label": "API URL",
      "description": "Google API URL",
      "type": "Hidden",
      "value": "= baseUrl + \"?conferenceDataVersion=1\"",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "condition": {
        "property": "meetingOperation",
        "equals": "scheduleMeetingInCalendar"
      }
    },
    {
      "id": "updateUrl",
      "type": "Hidden",
      "value": "= baseUrl + \"/\" + eventId + \"?sendUpdates=all\"",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "condition": {
        "property": "meetingOperation",
        "equals": "updateMeeting"
      }
    },
    {
      "id": "deleteUrl",
      "type": "Hidden",
      "value": "= baseUrl + \"/\" + eventId + \"?sendUpdates=all\"",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "condition": {
        "property": "meetingOperation",
        "equals": "cancelMeeting"
      }
    },
    {
      "id": "createMethod",
      "type": "Hidden",
      "value": "POST",
      "binding": {
        "type": "zeebe:input",
        "name": "method"
      }
    },
    {
      "id": "deleteMethod",
      "type": "Hidden",
      "value": "DELETE",
      "binding": {
        "type": "zeebe:input",
        "name": "method"
      },
      "condition": {
        "property": "meetingOperation",
        "equals": "cancelMeeting"
      }
    },
    {
      "id": "updateMethod",
      "type": "Hidden",
      "value": "PUT",
      "binding": {
        "type": "zeebe:input",
        "name": "method"
      },
      "condition": {
        "property": "meetingOperation",
        "equals": "updateMeeting"
      }
    },
    {
      "type": "Hidden",
      "value": "application/json",
      "binding": {
        "type": "zeebe:input",
        "name": "headers.ContentType"
      }
    },
    {
      "type": "Hidden",
      "binding": {
        "type": "zeebe:input",
        "name": "headers.Authorization"
      },
      "value": "= \"Bearer \" + accesstoken"
    },
    {
      "id": "requestId",
      "type": "Hidden",
      "value": "= \"meeting-\" + string(now())",
      "binding": {
        "type": "zeebe:input",
        "name": "requestId"
      }
    },
    {
      "label": "Request Body",
      "type": "Hidden",
      "value": "={\"summary\": summary,\"description\": description,\"start\":{\"dateTime\": startTime,\"timeZone\": if timeZone != null and timeZone != \"\" then timeZone else \"\"},\"end\":{\"dateTime\": endTime,\"timeZone\": if timeZone != null and timeZone != \"\" then timeZone else \"\"},\"attendees\": from json(attendees),\"conferenceData\":{\"createRequest\":{\"requestId\": requestId}}}",
      "binding": {
        "type": "zeebe:input",
        "name": "body"
      },
      "condition": {
        "property": "meetingOperation",
        "equals": "scheduleMeetingInCalendar"
      }
    },
    {
      "id": "updateBody",
      "label": "Request Body",
      "type": "Hidden",
      "value": "={\"summary\": summary,\"description\": description,\"start\":{\"dateTime\": startTime,\"timeZone\": if timeZone = null or timeZone = \"\" then \"\" else timeZone},\"end\":{\"dateTime\": endTime,\"timeZone\": if timeZone = null or timeZone = \"\" then \"\" else timeZone},\"attendees\": from json(attendees),\"conferenceData\":{\"createRequest\":{\"requestId\": requestId}}}",
      "binding": {
        "type": "zeebe:input",
        "name": "body"
      },
      "condition": {
        "property": "meetingOperation",
        "equals": "updateMeeting"
      }
    },
    {
      "id": "cancelBody",
      "label": "Request Body",
      "type": "Hidden",
      "value": "={\"summary\": summary,\"description\": description}",
      "binding": {
        "type": "zeebe:input",
        "name": "body"
      },
      "condition": {
        "property": "meetingOperation",
        "equals": "cancelMeeting"
      }
    },
    {
      "label": "Result Variable",
      "description": "Process variable to store response",
      "type": "String",
      "group": "output",
      "value": "result",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultVariable"
      }
    },
    {
      "label": "Result Expression",
      "description": "Expression to map the response into process variables",
      "type": "Text",
      "group": "output",
      "feel": "required",
      "value": "={ result: response.body }",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultExpression"
      }
    },
    {
      "id": "errorExpression",
      "label": "Error expression",
      "description": "Expression to handle errors. Details in the <a href=\"https://docs.camunda.io/docs/components/connectors/use-connectors/\" target=\"_blank\">documentation</a>.",
      "feel": "required",
      "type": "Text",
      "group": "errors",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      }
    },
    {
      "id": "connectionTimeout",
      "label": "Connection timeout",
      "description": "Timeout in seconds (0 for infinite)",
      "group": "retries",
      "type": "String",
      "value": "120",
      "binding": {
        "type": "zeebe:input",
        "name": "connectionTimeoutInSeconds"
      }
    },
    {
      "id": "retryCount",
      "label": "Retries",
      "description": "Number of retries",
      "value": "3",
      "feel": "optional",
      "group": "retries",
      "binding": {
        "property": "retries",
        "type": "zeebe:taskDefinition"
      },
      "type": "String"
    },
    {
      "id": "retryBackoff",
      "label": "Retry backoff",
      "description": "ISO-8601 duration to wait between retries",
      "value": "PT0S",
      "group": "retries",
      "binding": {
        "key": "retryBackoff",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    }
  ],
  "icon": {
    "contents": "data:image/png;base64,"
  }
}