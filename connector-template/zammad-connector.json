{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Zammad Connector",
  "id": "io.camunda.zammad-connector-template",
  "version": 20,
  "description": "Create, Search, Update, and Delete Zammad support tickets from Camunda 8 processes",
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "authentication",
      "label": "Authentication"
    },
    {
      "id": "domain",
      "label": "Domain"
    },
    {
      "id": "operation",
      "label": "Operation"
    },
    {
      "id": "parameters",
      "label": "Parameters"
    },
    {
      "id": "requestBody",
      "label": "Request Body"
    },
    {
      "id": "output",
      "label": "Response mapping"
    },
    {
      "id": "errors",
      "label": "Error handling"
    },
    {
      "id": "retries",
      "label": "Retries"
    }
  ],
  "properties": [
    {
      "value": "io.camunda:http-json:1",
      "binding": {
        "property": "type",
        "type": "zeebe:taskDefinition"
      },
      "type": "Hidden"
    },
    {
      "id": "accesstoken",
      "label": "Access Token",
      "description": "Enter Access Token",
      "type": "String",
      "group": "authentication",
      "feel": "optional",
      "binding": {
        "type": "zeebe:input",
        "name": "accesstoken"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "id": "zammadOperation",
      "label": "Zammad Operation",
      "description": "Select Zammad Operation",
      "type": "Dropdown",
      "group": "operation",
      "value": "createTicket",
      "choices": [
        {
          "name": "Create Ticket",
          "value": "createTicket"
        },
        {
          "name": "Update Ticket",
          "value": "updateTicket"
        },
        {
          "name": "Delete Ticket",
          "value": "deleteTicket"
        },
        {
          "name": "Get Ticket",
          "value": "getTicket"
        },
        {
          "name": "Search User",
          "value": "searchUser"
        },
        {
          "name": "Create User",
          "value": "createUser"
        }
      ],
      "binding": {
        "type": "zeebe:input",
        "name": "zammadOperation"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "id": "baseUrl",
      "label": "Domain",
      "description": "Enter the Zammad Base URL (eg. https://dev.example.com or IP adresss).",
      "feel": "optional",
      "type": "Text",
      "group": "domain",
      "binding": {
        "type": "zeebe:input",
        "name": "baseUrl"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "id": "title",
      "label": "Title",
      "description": "Enter the Title",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "title"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "createTicket",
          "updateTicket"
        ]
      }
    },
    {
      "id": "group",
      "label": "Group",
      "description": "Enter the Group Name",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "group"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "createTicket",
          "updateTicket"
        ]
      }
    },
    {
      "id": "email",
      "label": "Customer Email",
      "description": "Enter the Customer Email",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "email"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "createTicket",
          "updateTicket",
          "createUser"
        ]
      }
    },
    {
      "id": "firstName",
      "label": "First Name",
      "description": "Enter the First Name",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "firstName"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "equals": "createUser"
      }
    },
    {
      "id": "lastName",
      "label": "Last Name",
      "description": "Enter the Last Name",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "lastName"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "equals": "createUser"
      }
    },
    {
      "id": "state",
      "label": "State",
      "description": "Select the State of Ticket",
      "type": "Dropdown",
      "value": "open",
      "group": "requestBody",
      "choices": [
        {
          "name": "NEW",
          "value": "new"
        },
        {
          "name": "OPEN",
          "value": "open"
        },
        {
          "name": "CLOSED",
          "value": "closed"
        },
        {
          "name": "PENDING CLOSE",
          "value": "pending close"
        },
        {
          "name": "other",
          "value": "other"
        }
      ],
      "binding": {
        "type": "zeebe:input",
        "name": "state"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "createTicket",
          "updateTicket"
        ]
      }
    },
    {
      "id": "otherState",
      "label": "Other State",
      "description": "Enter State if 'Other' is selected",
      "type": "String",
      "group": "requestBody",
      "feel": "optional",
      "value": " ",
      "binding": {
        "type": "zeebe:input",
        "name": "state"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "state",
        "equals": "other"
      }
    },
    {
      "id": "priority",
      "label": "Priority",
      "description": "Enter the priority e.g : 1 low or 2 normal or 3 high",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "priority"
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "createTicket",
          "updateTicket"
        ]
      }
    },
    {
      "id": "subject",
      "label": "Subject",
      "description": "Enter the Subject ",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "subject"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "createTicket",
          "updateTicket"
        ]
      }
    },
    {
      "id": "messagebody",
      "label": "Message body",
      "description": "Enter the message body",
      "feel": "optional",
      "type": "Text",
      "group": "requestBody",
      "binding": {
        "type": "zeebe:input",
        "name": "messagebody"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "createTicket",
          "updateTicket"
        ]
      }
    },
    {
      "id": "internal",
      "label": "Internal",
      "type": "Dropdown",
      "group": "requestBody",
      "value": "false",
      "choices": [
        {
          "name": "True",
          "value": "true"
        },
        {
          "name": "False",
          "value": "false"
        }
      ],
      "binding": {
        "type": "zeebe:input",
        "name": "internal"
      },
      "condition": {
        "property": "zammadOperation",
        "equals": "createTicket"
      }
    },
    {
      "id": "ticketId",
      "label": "Ticket ID",
      "description": "Enter Ticket ID",
      "type": "Text",
      "feel": "optional",
      "group": "parameters",
      "binding": {
        "type": "zeebe:input",
        "name": "ticketId"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "updateTicket",
          "deleteTicket",
          "getTicket"
        ]
      }
    },
    {
      "id": "email",
      "label": "Email ID",
      "description": "Enter Email ID",
      "type": "Text",
      "feel": "optional",
      "group": "parameters",
      "binding": {
        "type": "zeebe:input",
        "name": "email"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "searchUser"
        ]
      }
    },
    {
      "id": "createTicketUrl",
      "label": "API URL",
      "description": "Create Ticket URL",
      "type": "Hidden",
      "value": "= baseUrl + \"/api/v1/tickets\"",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "condition": {
        "property": "zammadOperation",
        "equals": "createTicket"
      }
    },
    {
      "id": "commonTicketUrl",
      "type": "Hidden",
      "value": "=string(baseUrl) + \"/api/v1/tickets/\" + string(ticketId)",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "getTicket",
          "updateTicket",
          "deleteTicket"
        ]
      }
    },
    {
      "id": "searchUserurl",
      "type": "Hidden",
      "value": "=baseUrl + \"/api/v1/users/search?query=\" + email",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "condition": {
        "property": "zammadOperation",
        "equals": "searchUser"
      }
    },
    {
      "id": "createUserurl",
      "type": "Hidden",
      "value": "=baseUrl + \"/api/v1/users\"",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "condition": {
        "property": "zammadOperation",
        "equals": "createUser"
      }
    },
    {
      "id": "createMethod",
      "type": "Hidden",
      "value": "POST",
      "binding": {
        "type": "zeebe:input",
        "name": "method"
      }
    },
    {
      "id": "getMethod",
      "type": "Hidden",
      "value": "GET",
      "binding": {
        "type": "zeebe:input",
        "name": "method"
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "searchUser",
          "getTicket"
        ]
      }
    },
    {
      "id": "deleteMethod",
      "type": "Hidden",
      "value": "DELETE",
      "binding": {
        "type": "zeebe:input",
        "name": "method"
      },
      "condition": {
        "property": "zammadOperation",
        "equals": "deleteTicket"
      }
    },
    {
      "id": "updateMethod",
      "type": "Hidden",
      "value": "PUT",
      "binding": {
        "type": "zeebe:input",
        "name": "method"
      },
      "condition": {
        "property": "zammadOperation",
        "equals": "updateTicket"
      }
    },
    {
      "type": "Hidden",
      "value": "application/json",
      "binding": {
        "type": "zeebe:input",
        "name": "headers.ContentType"
      }
    },
    {
      "type": "Hidden",
      "binding": {
        "type": "zeebe:input",
        "name": "headers.Authorization"
      },
      "value": "= \"Token token=\" + accesstoken"
    },
    {
      "label": "Request Body",
      "type": "Hidden",
      "value": "={\"title\": title,\"customer\": email,\"group\": group,\"state\": state,\"priority\": priority,\"article\":{\"subject\": subject,\"body\": messagebody,\"internal\": if internal = \"true\" then true else false}}",
      "binding": {
        "type": "zeebe:input",
        "name": "body"
      },
      "condition": {
        "property": "zammadOperation",
        "oneOf": [
          "createTicket",
          "updateTicket"
        ]
      }
    },
    {
      "label": "Request Body",
      "type": "Hidden",
      "value": "={\"firstname\": firstname,\"lastname\": lastname,\"email\": email,\"role_ids\": [3]}",
      "name": "body",
      "binding": {
        "type": "zeebe:input",
        "name": "body"
      },
      "condition": {
        "property": "zammadOperation",
        "equals": "createUser"
      }
    },
    {
      "label": "Result Variable",
      "description": "Process variable to store response",
      "type": "String",
      "group": "output",
      "value": "result",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultVariable"
      }
    },
    {
      "label": "Result Expression",
      "description": "Expression to map the response into process variables",
      "type": "Text",
      "group": "output",
      "feel": "required",
      "value": "={ result: response.body }",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultExpression"
      }
    },
    {
      "id": "errorExpression",
      "label": "Error expression",
      "description": "Expression to handle errors. Details in the <a href=\"https://docs.camunda.io/docs/components/connectors/use-connectors/\" target=\"_blank\">documentation</a>.",
      "feel": "required",
      "type": "Text",
      "group": "errors",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      }
    },
    {
      "id": "connectionTimeout",
      "label": "Connection timeout",
      "description": "Timeout in seconds (0 for infinite)",
      "group": "retries",
      "type": "String",
      "value": "120",
      "binding": {
        "type": "zeebe:input",
        "name": "connectionTimeoutInSeconds"
      }
    },
    {
      "id": "retryCount",
      "label": "Retries",
      "description": "Number of retries",
      "value": "3",
      "feel": "optional",
      "group": "retries",
      "binding": {
        "property": "retries",
        "type": "zeebe:taskDefinition"
      },
      "type": "String"
    },
    {
      "id": "retryBackoff",
      "label": "Retry backoff",
      "description": "ISO-8601 duration to wait between retries",
      "value": "PT0S",
      "group": "retries",
      "binding": {
        "key": "retryBackoff",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    }
  ],
  "icon": {
    "contents": "data:image/png;base64,"
  }
}